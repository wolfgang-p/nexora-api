# Koro API — environment template. Copy to .env and fill in.
# NEVER commit .env to git (already in .gitignore).

# ── Server ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated list of origins allowed for CORS (web app, CRM)
CORS_ORIGINS=*,http://localhost:3000,https://koro.chat,https://crm.koro.chat,http://152.53.14.141:3001,https://web.koro.chat,https://*.nexoro.net,https://nexoro.net

# ── Supabase ─────────────────────────────────────────────────────────
# Project settings → API → URL
SUPABASE_URL=
# Project settings → API → service_role key (BACKEND ONLY, NEVER ship to client)
SUPABASE_SERVICE_ROLE_KEY=
# Project settings → API → anon key (public, used by end-user clients if they talk to Supabase directly)
SUPABASE_ANON_KEY=

# ── Auth ─────────────────────────────────────────────────────────────
# 64+ random bytes, base64 encoded. Generate: openssl rand -base64 64
JWT_SECRET=
# Access token lifetime in seconds (default: 15 min)
JWT_ACCESS_TTL=900
# Refresh token lifetime in seconds (default: 30 days)
JWT_REFRESH_TTL=2592000

# ── OTP ──────────────────────────────────────────────────────────────
# SMS provider (twilio, messagebird, etc. — TBD)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=    # Twilio-owned number or alpha-sender ID
TWILIO_STATUS_CALLBACK=https://api.koro.chat/sms/twilio-status  # optional

# ── Media storage ────────────────────────────────────────────────────
# Supabase Storage bucket for encrypted media blobs (private, signed URLs only)
MEDIA_BUCKET=koro-media

# ── Push notifications ───────────────────────────────────────────────
# Expo access token (optional, for higher rate limits)
EXPO_ACCESS_TOKEN=

# Bot Device for Message History Sync
BOT_DEVICE_ID=5f5aa645-8912-4ebe-9452-e58b427a6f8a
BOT_DEVICE_PRIVATE_KEY="3d87iatPzCpvjea28BBQnW3O1lb9NzAP77bjgJm3Ssw="

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-haiku-4-5 
TURN_TOKEN=
TURN_KEY_ID=
STATUS_PASSWORD=